    unified_info_path = project_root / config['paths']['unified_info']
    unified_info_df = load_unified_info(unified_info_path)
    unified_info_mapping, has_duplicates_mapping = create_unified_info_mapping(unified_info_df)

    # Find all speaker data files
    inputs_dir = project_root / config['paths']['inputs']
    speaker_files = sorted(inputs_dir.glob('speaker_data_*.parquet'))

    print(f"\nFound {len(speaker_files)} speaker data files")

    # Process each year
    all_stats = []

    for speaker_file in speaker_files:
        # Extract year from filename
        year = int(speaker_file.stem.split('_')[-1])

        # Skip if outside configured range
        if year < config['data']['year_start'] or year > config['data']['year_end']:
            print(f"\nSkipping year {year} (outside configured range)")
            continue

        # Process year
        docs_df, stats = process_year(
            year=year,
            speaker_data_path=speaker_file,
            unified_info_mapping=unified_info_mapping,
            has_duplicates_mapping=has_duplicates_mapping,
            config=config
        )

        # Write output if we have data
        if len(docs_df) > 0:
            output_filename = f"qa_manager_docs_{year}.parquet"
            output_path = timestamped_output_dir / output_filename
            write_docs_parquet(docs_df, output_path)

        all_stats.append(stats)

    # Re-sort records by actual year to fix date misalignment
    print("\n" + "=" * 80)
    print("POST-PROCESSING: Re-sorting records by actual year")
    print("=" * 80)
    resort_records_by_actual_year(timestamped_output_dir, config)

    # Record end time
    end_time = datetime.now()
    duration = (end_time - start_time).total_seconds()

    # Generate report
    report_filename = config['step_02']['outputs']['summary_report']
    report_path = timestamped_output_dir / report_filename

    generate_report(
        config=config,
        all_stats=all_stats,
        output_dir=timestamped_output_dir,
        report_path=report_path,
        start_time=start_time,
        end_time=end_time
    )

    # Print summary
    print("\n" + "=" * 80)
    print("STEP 02: COMPLETED SUCCESSFULLY")
    print("=" * 80)
    print(f"Duration: {duration:.2f} seconds")
    print(f"Years processed: {len(all_stats)}")
    print(f"Total file_names: {sum(s['file_names_processed'] for s in all_stats):,}")
    print(f"Total managerial Q&A turns: {sum(s['managerial_qa_turns'] for s in all_stats):,}")
    print(f"Output directory: {timestamped_output_dir}")
    print(f"Summary report: {report_path}")
    print(f"Latest symlink: {latest_output_dir}")
    print(f"Log file: {log_file_path}")
    print("=" * 80)

    # Close dual writer
    dual_writer.close()
    sys.stdout = dual_writer.terminal


if __name__ == '__main__':
    main()
