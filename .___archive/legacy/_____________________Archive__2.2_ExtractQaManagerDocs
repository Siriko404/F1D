def resort_records_by_actual_year(output_dir: Path, config: Dict[str, Any]):
    """
    Re-sort all records by their actual year to fix date misalignment.

    Reads all qa_manager_docs_YYYY.parquet files, consolidates them,
    and re-writes them sorted by the 'year' column.
    """
    print("\nStep 1: Loading all year files...")

    year_start = config['data']['year_start']
    year_end = config['data']['year_end']

    all_dfs = []
    total_rows = 0

    for year in range(year_start, year_end + 1):
        year_file = output_dir / f"qa_manager_docs_{year}.parquet"
        if year_file.exists():
            df = pd.read_parquet(year_file)
            all_dfs.append(df)
            total_rows += len(df)
            print(f"  Loaded {year}: {len(df):,} documents")
        else:
            print(f"  WARNING: Missing {year_file.name}")

    if not all_dfs:
        print("ERROR: No data files found for re-sorting")
        return

    # Concatenate all data
    print(f"\nStep 2: Concatenating all data ({total_rows:,} total documents)")
    combined = pd.concat(all_dfs, ignore_index=True)
    print(f"  Combined shape: {combined.shape}")

    # Check year distribution before re-sorting
    print("\nYear distribution BEFORE re-sorting:")
    year_counts_before = {}
    for year in range(year_start, year_end + 1):
        count = (combined['year'] == year).sum()
        if count > 0:
            year_counts_before[year] = count
            print(f"  {year}: {count:,} documents")

    # Re-group by actual year and re-write files
    print("\nStep 3: Re-writing files sorted by actual year...")

    # First, delete old year files
    for year in range(year_start, year_end + 1):
        year_file = output_dir / f"qa_manager_docs_{year}.parquet"
        if year_file.exists():
            year_file.unlink()

    # Write new year files
    year_counts_after = {}
    for year, group in combined.groupby('year', sort=True):
        # Sort by file_name for determinism
        group_sorted = group.sort_values('file_name').reset_index(drop=True)

        # Write parquet
        output_path = output_dir / f"qa_manager_docs_{year}.parquet"
        write_docs_parquet(group_sorted, output_path)

        year_counts_after[year] = len(group_sorted)
        print(f"  Written {year}: {len(group_sorted):,} documents")

    # Summary
    print(f"\n{'='*80}")
    print("Re-sorting Summary")
    print(f"{'='*80}")
    print(f"Total documents: {total_rows:,}")
    print(f"Years processed: {len(year_counts_after)}")

    # Check for any year mismatches
    mismatches = []
    for year in year_counts_before.keys():
        count_file = 0
        for y in range(year_start, year_end + 1):
            if y == year:
                continue
            year_file = output_dir / f"qa_manager_docs_{y}.parquet"
            if year_file.exists():
                df_temp = pd.read_parquet(year_file)
                count_in_wrong_file = (df_temp['year'] == year).sum()
                if count_in_wrong_file > 0:
                    mismatches.append(f"  WARNING: {count_in_wrong_file} records from year {year} found in {y} file")

    if mismatches:
        print("\n QUALITY CHECK FAILED - Mismatches found:")
        for msg in mismatches:
            print(msg)
    else:
        print("\n✓ QUALITY CHECK PASSED - All records in correct year files")

    print(f"{'='*80}\n")


