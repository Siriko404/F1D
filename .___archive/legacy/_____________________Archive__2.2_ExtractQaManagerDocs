class DualWriter:
    """Write to both stdout and log file simultaneously (verbatim)."""

    def __init__(self, log_file_path: Path):
        self.terminal = sys.stdout
        self.log_file = open(log_file_path, 'w', encoding='utf-8')

    def write(self, message: str):
        """Write message to both stdout and log file."""
        self.terminal.write(message)
        self.log_file.write(message)
        self.flush()

    def flush(self):
        """Flush both streams."""
        self.terminal.flush()
        self.log_file.flush()

    def close(self):
        """Close log file."""
        self.log_file.close()


def load_config(config_path: Path) -> Dict[str, Any]:
    """Load central configuration from YAML."""
    with open(config_path, 'r') as f:
        return yaml.safe_load(f)


def create_timestamped_output_dir(base_output_dir: Path) -> Tuple[Path, Path]:
    """Create timestamped output directory and latest symlink."""
    timestamp = datetime.now().strftime('%Y-%m-%d_%H%M%S')
    timestamped_dir = base_output_dir / timestamp
    latest_dir = base_output_dir / 'latest'

    # Create timestamped directory
    timestamped_dir.mkdir(parents=True, exist_ok=True)

    # Update latest symlink (remove old one if exists)
    if latest_dir.exists() or latest_dir.is_symlink():
        latest_dir.unlink()

    # Create new symlink (use relative path for portability)
    latest_dir.symlink_to(timestamp, target_is_directory=True)

    return timestamped_dir, latest_dir


def load_unified_info(unified_info_path: Path) -> pd.DataFrame:
    """Load and prepare Unified Info for joining."""
    print(f"\nLoading Unified Info from: {unified_info_path}")
    df = pd.read_parquet(unified_info_path)
    print(f"  Loaded {len(df):,} rows")

    # Remove exact duplicates
    original_len = len(df)
    df = df.drop_duplicates(keep='first')
    if len(df) < original_len:
        print(f"  Removed {original_len - len(df):,} exact duplicate rows")

    return df


def select_unified_info_row(rows: pd.DataFrame) -> pd.Series:
    """
    Deterministic selection from multiple Unified Info rows for same file_name.

    Sort by:
    1. validation_timestamp (earliest first, nulls last)
    2. start_date (earliest first, nulls last)
    3. Lexicographic on all columns (for stable tie-break)

    Returns first row after sorting.
    """
    if len(rows) == 1:
        return rows.iloc[0]

    # Sort by validation_timestamp (nulls last)
    rows = rows.copy()
    rows['_vt_sort'] = pd.to_datetime(rows['validation_timestamp'], errors='coerce')
    rows = rows.sort_values('_vt_sort', na_position='last')

    # If still tied, sort by start_date
    if rows['_vt_sort'].iloc[0] == rows['_vt_sort'].iloc[1]:
        rows['_sd_sort'] = pd.to_datetime(rows['start_date'], errors='coerce')
        rows = rows.sort_values(['_vt_sort', '_sd_sort'], na_position='last')

    # If still tied, sort lexicographically on all columns
    if len(rows) > 1:
        # Convert all columns to string for stable sort
        sort_cols = [col for col in rows.columns if not col.startswith('_')]
        rows = rows.sort_values(sort_cols)

    return rows.iloc[0]


def create_unified_info_mapping(unified_info_df: pd.DataFrame) -> Tuple[Dict[str, pd.Series], Dict[str, bool]]:
    """
    Create mapping from file_name to selected Unified Info row.

    Returns:
    - Dictionary: file_name -> selected row (as Series)
    - Dictionary: file_name -> has_duplicates (bool)
    """
    print("\nCreating Unified Info mapping...")

    mapping = {}
    has_duplicates = {}

    grouped = unified_info_df.groupby('file_name')

    for file_name, group in grouped:
        if len(group) > 1:
            # Multiple rows - use deterministic selection
            selected_row = select_unified_info_row(group)
            mapping[file_name] = selected_row
            has_duplicates[file_name] = True
        else:
            # Single row
            mapping[file_name] = group.iloc[0]
            has_duplicates[file_name] = False

    num_with_dups = sum(has_duplicates.values())
    print(f"  Created mapping for {len(mapping):,} file_names")
    print(f"  {num_with_dups:,} file_names had multiple Unified Info rows (used deterministic selection)")

    return mapping, has_duplicates


def is_managerial_speaker(row: pd.Series,
                         company_name: str,
                         managerial_roles: List[str],
                         exclusion_keywords: List[str]) -> Tuple[bool, str]:
    """
    Determine if a speaker is managerial based on role and employer.

    Returns:
    - bool: True if managerial, False otherwise
    - str: Reason for inclusion/exclusion
    """
    role = str(row.get('role', '')).strip()
    employer = str(row.get('employer', '')).strip()
    speaker_name = str(row.get('speaker_name', '')).strip()

    # Check exclusion keywords first (in role or speaker_name)
    for keyword in exclusion_keywords:
        if keyword.lower() in role.lower() or keyword.lower() in speaker_name.lower():
            return False, f'excluded_{keyword.lower()}'

    # Check employer match (case-insensitive, trimmed)
    if employer and company_name:
        if employer.lower() == company_name.lower():
            return True, 'employer_match'

    # Check managerial role keywords
    if role:
        for keyword in managerial_roles:
            if keyword.lower() in role.lower():
                return True, f'role_{keyword.lower()}'

    return False, 'no_match'


def process_year(year: int,
                speaker_data_path: Path,
                unified_info_mapping: Dict[str, pd.Series],
                has_duplicates_mapping: Dict[str, bool],
                config: Dict[str, Any]) -> Tuple[pd.DataFrame, Dict[str, Any]]:
    """
    Process speaker data for one year.

    Returns:
    - DataFrame with qa_manager_docs
    - Dictionary with statistics
    """
    print(f"\n{'='*80}")
    print(f"Processing Year: {year}")
    print(f"{'='*80}")

    # Load speaker data
    print(f"Loading speaker data: {speaker_data_path}")
    df = pd.read_parquet(speaker_data_path)
    print(f"  Loaded {len(df):,} rows")

    stats = {
        'year': year,
        'total_turns': len(df),
        'qa_turns': 0,
        'managerial_qa_turns': 0,
        'excluded_analyst': 0,
        'excluded_operator': 0,
        'excluded_other': 0,
        'included_employer': 0,
        'included_role': 0,
        'file_names_processed': 0,
        'file_names_with_mapping_issues': 0,
        'empty_role_count': 0,
        'empty_employer_count': 0,
        'role_keywords_seen': defaultdict(int)
    }

    # Filter for Q&A context
    print("\nFiltering for Q&A context...")
    df_qa = df[df['context'] == 'qa'].copy()
    stats['qa_turns'] = len(df_qa)
    print(f"  Q&A turns: {stats['qa_turns']:,} ({stats['qa_turns']/stats['total_turns']*100:.1f}%)")

    if len(df_qa) == 0:
        print("  No Q&A turns found - skipping year")
        return pd.DataFrame(), stats

    # Apply managerial filter
    print("\nApplying managerial filter...")

    managerial_roles = config['step_02']['managerial_roles']
    exclusion_keywords = config['step_02']['exclusion_keywords']

    # Add columns for filtering results
    df_qa['is_managerial'] = False
    df_qa['filter_reason'] = ''
    df_qa['company_name_from_unified'] = ''
    df_qa['has_mapping_issues'] = False

    # Process each row
    for idx, row in df_qa.iterrows():
        file_name = row['file_name']

        # Get company_name from Unified Info
        if file_name in unified_info_mapping:
            unified_row = unified_info_mapping[file_name]
            company_name = str(unified_row.get('company_name', '')).strip()
            has_issues = has_duplicates_mapping.get(file_name, False)

            df_qa.at[idx, 'company_name_from_unified'] = company_name
            df_qa.at[idx, 'has_mapping_issues'] = has_issues

            # Check if managerial
            is_mgr, reason = is_managerial_speaker(row, company_name, managerial_roles, exclusion_keywords)
            df_qa.at[idx, 'is_managerial'] = is_mgr
            df_qa.at[idx, 'filter_reason'] = reason

            # Update stats
            if is_mgr:
                if reason == 'employer_match':
                    stats['included_employer'] += 1
                elif reason.startswith('role_'):
                    stats['included_role'] += 1
                    role_keyword = reason.split('_', 1)[1].upper()
                    stats['role_keywords_seen'][role_keyword] += 1
            else:
                if reason.startswith('excluded_analyst'):
                    stats['excluded_analyst'] += 1
                elif reason.startswith('excluded_operator'):
                    stats['excluded_operator'] += 1
                elif reason.startswith('excluded_'):
                    stats['excluded_other'] += 1
        else:
            # file_name not in Unified Info - cannot determine company_name
            df_qa.at[idx, 'is_managerial'] = False
            df_qa.at[idx, 'filter_reason'] = 'no_unified_info'

    # Keep only managerial Q&A turns
    df_managerial = df_qa[df_qa['is_managerial']].copy()
    stats['managerial_qa_turns'] = len(df_managerial)

    print(f"  Managerial Q&A turns: {stats['managerial_qa_turns']:,} ({stats['managerial_qa_turns']/stats['qa_turns']*100:.1f}% of Q&A)")
    print(f"    Included by employer match: {stats['included_employer']:,}")
    print(f"    Included by role keyword: {stats['included_role']:,}")
    print(f"    Excluded (Analyst): {stats['excluded_analyst']:,}")
    print(f"    Excluded (Operator): {stats['excluded_operator']:,}")
    print(f"    Excluded (Other): {stats['excluded_other']:,}")

    # Count empty role/employer
    stats['empty_role_count'] = df_qa['role'].isna().sum() + (df_qa['role'] == '').sum()
    stats['empty_employer_count'] = df_qa['employer'].isna().sum() + (df_qa['employer'] == '').sum()

    print(f"    Empty role fields: {stats['empty_role_count']:,} ({stats['empty_role_count']/len(df_qa)*100:.1f}%)")
    print(f"    Empty employer fields: {stats['empty_employer_count']:,} ({stats['empty_employer_count']/len(df_qa)*100:.1f}%)")

    if len(df_managerial) == 0:
        print("  No managerial Q&A turns found - skipping year")
        return pd.DataFrame(), stats

    # Concatenate text per file_name
    print("\nConcatenating text per file_name...")

    docs = []
    for file_name, group in df_managerial.groupby('file_name'):
        # Concatenate speaker_text (in order)
        texts = group['speaker_text'].fillna('').tolist()
        doc_text = ' '.join(texts)

        # Get year from Unified Info or fall back to source year
        if file_name in unified_info_mapping:
            unified_row = unified_info_mapping[file_name]
            try:
                start_date = pd.to_datetime(unified_row.get('start_date'), errors='coerce')
                doc_year = start_date.year if pd.notna(start_date) else year
            except:
                doc_year = year
            has_issues = has_duplicates_mapping.get(file_name, False)
        else:
            doc_year = year
            has_issues = False

        docs.append({
            'file_name': file_name,
            'doc_text': doc_text,
            'approx_char_len': len(doc_text),
            'year': int(doc_year)
        })

        if has_issues:
            stats['file_names_with_mapping_issues'] += 1

    stats['file_names_processed'] = len(docs)

    print(f"  Created {len(docs):,} documents")
    print(f"  {stats['file_names_with_mapping_issues']:,} file_names had Unified Info mapping issues")

    # Convert to DataFrame
    docs_df = pd.DataFrame(docs)

    # Sort by file_name for determinism
    docs_df = docs_df.sort_values('file_name').reset_index(drop=True)

    return docs_df, stats


def write_docs_parquet(df: pd.DataFrame, output_path: Path):
    """Write qa_manager_docs to Parquet."""
    print(f"\nWriting to: {output_path}")

    # Define schema
    schema = pa.schema([
        ('file_name', pa.string()),
        ('doc_text', pa.string()),
        ('approx_char_len', pa.int64()),
        ('year', pa.int64())
    ])

    # Convert to PyArrow table
    table = pa.Table.from_pandas(df, schema=schema)

    # Write with compression
    pq.write_table(
        table,
        output_path,
        compression='snappy',
        use_dictionary=True
    )

    file_size = output_path.stat().st_size
    print(f"  Written {len(df):,} rows ({file_size:,} bytes)")


