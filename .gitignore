# ==============================================================================
# DATA DIRECTORIES (ARCH-03 structure)
# ==============================================================================

# Raw data - ignore data files but track README
data/raw/*.parquet
data/raw/*.csv
data/raw/*.zip
data/raw/*.sas7bdat
data/raw/*.dta
!data/raw/README.md

# Interim data - can be regenerated
data/interim/*
!data/interim/README.md
!data/interim/.gitkeep

# Processed data - ignore data files but track README and validation
data/processed/*.parquet
data/processed/*.csv
!data/processed/README.md
!data/processed/**/VALIDATION.md
!data/processed/**/*.yaml

# External data - track README only
data/external/*
!data/external/README.md
!data/external/.gitkeep

# ==============================================================================
# LOGS DIRECTORY
# ==============================================================================

logs/*.log
logs/*.txt
!logs/.gitkeep

# ==============================================================================
# RESULTS DIRECTORY (analysis outputs - always ignored)
# ==============================================================================

results/*
!results/.gitkeep
!results/*/.gitkeep

# ==============================================================================
# LEGACY PATHS (will be removed in v7.0)
# ==============================================================================

1_Inputs/
4_Outputs/
3_Logs/

# ==============================================================================
# ARCHIVES AND BACKUPS
# ==============================================================================

___Archive/
.___archive/
BACKUP_*/
*.rar
*.bak
*_backup.py
*_old.py

# ==============================================================================
# TEMPORARY FILES
# ==============================================================================

*.tmp
*.temp
nul
=*

# ==============================================================================
# RUFF AND MYPY CACHE
# ==============================================================================

.ruff_cache/
.mypy_cache/
.benchmarks/

# ==============================================================================
# ARCHIVE (consolidated)
# ==============================================================================

_archive/
